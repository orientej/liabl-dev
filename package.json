{
  "name": "liabl",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "start:web": "npm run start --workspace=apps/web",
    "dev:marketing": "npm run dev --workspace=apps/marketing",
    "build:marketing": "npm run build --workspace=apps/marketing",
    "build": "npm run build --workspace=apps/web && npm run build --workspace=apps/marketing"
  }
}
